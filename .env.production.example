# Production deployment checklist — copy values into your hosting dashboards.
# Never commit real secrets. See DEPLOY.md for step-by-step instructions.

# --- API (Render / Railway / Docker) ---
ENVIRONMENT=production
LOG_FORMAT=json
LOG_LEVEL=INFO
REQUIRE_AUTH=true

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase connection pooler (port 6543) recommended
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Comma-separated web origins (Vercel URL + custom domain)
CORS_ORIGINS=https://your-app.vercel.app,https://your-domain.com

# Optional: invite links default to first CORS origin if unset
# WEB_APP_URL=https://your-domain.com

SEASON_ZONE_CACHE_TTL_SECONDS=300
# Enable after running refresh_season_team_zone_stats() in Supabase
USE_ZONE_MATERIALIZED_VIEW=false

# --- Web (Vercel) ---
NEXT_PUBLIC_API_URL=https://your-api.onrender.com
NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key