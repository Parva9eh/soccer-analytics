# Production deployment checklist — Vercel-only (two projects + Supabase).
# Copy values into each Vercel project's Environment Variables dashboard.
# Never commit real secrets.

# =============================================================================
# API Vercel project (Root Directory: apps/api)
# =============================================================================
ENVIRONMENT=production
LOG_FORMAT=json
LOG_LEVEL=INFO
REQUIRE_AUTH=true

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase connection pooler (port 6543) recommended
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Web origin(s) — Option B cross-origin; still set for Option A same-origin proxy
CORS_ORIGINS=https://soccer-analytics-web.vercel.app,https://your-domain.com

# Optional: invite links default to first CORS origin if unset
# WEB_APP_URL=https://soccer-analytics-web.vercel.app

SEASON_ZONE_CACHE_TTL_SECONDS=300
USE_ZONE_MATERIALIZED_VIEW=false

# =============================================================================
# Web Vercel project (Root Directory: apps/web)
# =============================================================================

# --- Option A: same-origin proxy (recommended) ---
API_PROXY_TARGET=https://soccer-analytics-api.vercel.app
NEXT_PUBLIC_API_URL=https://soccer-analytics-web.vercel.app/backend

# --- Option B: cross-origin (comment out Option A, use these) ---
# NEXT_PUBLIC_API_URL=https://soccer-analytics-api.vercel.app

NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key