# ===========================================
# Soccer Analytics API - Environment Variables
# Copy this file to `.env` and fill in your real values.
# NEVER commit the actual `.env` file.
# ===========================================

# --- Supabase Configuration (Required) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (Settings → API in Supabase). Required when REQUIRE_AUTH=true
SUPABASE_JWT_SECRET=your-jwt-secret-here

# When true, API routes require Authorization: Bearer <supabase_access_token>
REQUIRE_AUTH=false

# --- Database Connection (Required) ---
# Use Supabase Connection Pooling URL (recommended for production)
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# --- Logging Configuration ---
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                   # text | json
LOG_EXCLUDED_PATHS=/health,/docs  # comma-separated paths to exclude from request logs

# --- CORS Configuration ---
CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Optional: web app URL for workspace invite links (defaults to first CORS origin)
# WEB_APP_URL=http://localhost:3000

# --- Environment / Observability ---
ENVIRONMENT=development           # development | staging | production

# --- Season zone aggregates ---
SEASON_ZONE_CACHE_TTL_SECONDS=300
# Set true after refreshing season_team_zone_stats materialized view (full-season datasets)
USE_ZONE_MATERIALIZED_VIEW=false

