# ===========================================
# Soccer Analytics API - Environment Variables
# Copy this file to `.env` and fill in your real values.
# NEVER commit the actual `.env` file.
# ===========================================

# --- Supabase Configuration (Required) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Database Connection (Required) ---
# Use Supabase Connection Pooling URL (recommended for production)
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# --- Logging Configuration ---
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                   # text | json
LOG_EXCLUDED_PATHS=/health,/docs  # comma-separated paths to exclude from request logs

# --- CORS Configuration ---
CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# --- Environment / Observability ---
ENVIRONMENT=development           # development | staging | production

