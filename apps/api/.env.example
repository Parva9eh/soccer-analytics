# ===========================================
# Soccer Analytics API - Environment Variables
# Copy this file to `.env` and fill in your real values.
# NEVER commit the actual `.env` file.
# ===========================================

# --- Supabase Configuration ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Database Connection (Use Connection Pooling) ---
# Get from Supabase → Settings → Database → Connection pooling (URI format)
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# ===========================================
# Important Notes:
# - SUPABASE_SERVICE_ROLE_KEY should only be used on the backend
# - For production (Render), set these as environment variables (not in code)
# - Use the Connection Pooling URL for DATABASE_URL
# ===========================================
