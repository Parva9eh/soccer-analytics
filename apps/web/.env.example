# Soccer Analytics Web - Environment Variables
# Copy this file to .env.local (or .env) and update as needed

# URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Supabase Auth (Phase 3) ---
# Required when NEXT_PUBLIC_AUTH_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Set to true to require login for all app routes (except /login, /signup, /auth)
NEXT_PUBLIC_AUTH_ENABLED=false
